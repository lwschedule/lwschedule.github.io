#!/usr/bin/env bash
# Post-commit hook to auto-bump README version, update sw.js cache name,
# add a changelog entry with the correct commit title, and amend the commit.
# To enable locally: git config core.hooksPath .githooks

set -euo pipefail
ROOT=$(cd "$(dirname "$0")/.." && pwd)
SCRIPT="$ROOT/.github/scripts/auto_bump_version.py"
if [ -x "$SCRIPT" ] || [ -f "$SCRIPT" ]; then
  python3 "$SCRIPT" || true
fi

exit 0
